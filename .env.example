# Resend transactional email API key. Required by the Cloudflare Pages
# Function at /api/contact.
RESEND_API_KEY=

# Inbox that receives quote requests from the homepage and /contact.
CONTACT_TO_EMAIL=luibrandtilecompany@gmail.com

# Sender for outbound email. Must be a verified sender or a verified domain
# in Resend before production email will deliver reliably. See
# docs/contact-form-setup.md for setup steps.
CONTACT_FROM_EMAIL="Luibrand Tile <quotes@luibrandtile.com>"

# Public site URL used for canonical URLs and metadata.
NEXT_PUBLIC_SITE_URL=https://luibrandtile.com

# Public site display name.
NEXT_PUBLIC_SITE_NAME="Luibrand Tile"

# Optional ownership verification tokens for search engines. Prefer DNS
# verification when possible; use these only if a meta tag is required.
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
NEXT_PUBLIC_BING_SITE_VERIFICATION=
